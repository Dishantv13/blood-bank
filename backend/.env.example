# ==================== DATABASE ====================
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/bloodbank

# ==================== JWT SECRETS (REQUIRED - each must be unique & >=32 chars) ====================
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# User authentication tokens
USER_ACCESS_TOKEN_SECRET=your_strong_user_access_secret_min_32_chars_xxxxxxxxxxxxxxxxxxxxxxxx
USER_REFRESH_TOKEN_SECRET=your_strong_user_refresh_secret_min_32_chars_xxxxxxxxxxxxxxxxxxxxxxxxx

# Admin authentication tokens
ADMIN_ACCESS_TOKEN_SECRET=your_strong_admin_access_secret_min_32_chars_xxxxxxxxxxxxxxxxxxxxxxxx
ADMIN_REFRESH_TOKEN_SECRET=your_strong_admin_refresh_secret_min_32_chars_xxxxxxxxxxxxxxxxxxxxxxxxx

# Blood bank authentication tokens
BLOODBANK_ACCESS_TOKEN_SECRET=your_strong_bloodbank_access_secret_min_32_chars_xxxxxxxxxxxxxxxxxx
BLOODBANK_REFRESH_TOKEN_SECRET=your_strong_bloodbank_refresh_secret_min_32_chars_xxxxxxxxxxxxxxxxxxx

# CSRF token hashing secret (optional, falls back to JWT_SECRET)
CSRF_HASH_SECRET=your_strong_csrf_hash_secret_min_32_chars_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==================== TOKEN EXPIRATION ====================
USER_ACCESS_TOKEN_EXPIRES_IN=15m
USER_REFRESH_TOKEN_EXPIRES_IN=7d

ADMIN_ACCESS_TOKEN_EXPIRES_IN=15m
ADMIN_REFRESH_TOKEN_EXPIRES_IN=7d

BLOODBANK_ACCESS_TOKEN_EXPIRES_IN=15m
BLOODBANK_REFRESH_TOKEN_EXPIRES_IN=30d

# ==================== COOKIE CONFIGURATION ====================
# Cookie names for different auth roles
USER_ACCESS_COOKIE_NAME=bb_user_at
USER_REFRESH_COOKIE_NAME=bb_user_rt
USER_CSRF_COOKIE_NAME=bb_user_csrf

ADMIN_ACCESS_COOKIE_NAME=bb_admin_at
ADMIN_REFRESH_COOKIE_NAME=bb_admin_rt
ADMIN_CSRF_COOKIE_NAME=bb_admin_csrf

BLOODBANK_ACCESS_COOKIE_NAME=bb_bank_at
BLOODBANK_REFRESH_COOKIE_NAME=bb_bank_rt
BLOODBANK_CSRF_COOKIE_NAME=bb_bank_csrf

# Blood bank registration OTP security
BLOODBANK_OTP_EXPIRY_MINUTES=10
BLOODBANK_OTP_MAX_VERIFY_ATTEMPTS=5
BLOODBANK_OTP_MAX_RESEND_ATTEMPTS=5
BLOODBANK_OTP_RESEND_COOLDOWN_SECONDS=60
BLOODBANK_PENDING_REGISTRATION_TTL_MINUTES=60
BLOODBANK_OTP_HASH_SECRET=your_strong_bloodbank_otp_hash_secret

# Cookie security settings
# For production: set to 'none', for dev: set to 'lax' or 'strict'
AUTH_COOKIE_SAME_SITE=lax

# Set to 'true' for HTTPS-only cookies (required for SameSite=none)
AUTH_COOKIE_SECURE=false

# Cookie domain (optional) - e.g., example.com or https://example.com
# Leave empty to use browser's default (current domain)
AUTH_COOKIE_DOMAIN=

# ==================== CORS CONFIGURATION ====================
FRONTEND_URL=http://localhost:3000
FRONTEND_URLS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000

# Allow requests without Origin header (not recommended for production)
ALLOW_NO_ORIGIN=false

# ==================== ADMIN CREDENTIALS ====================
ADMIN_EMAIL=admin@example.com
# Generate hash: bcrypt.hashSync('password', 10)
ADMIN_PASSWORD_HASH=$2b$10$your_bcrypt_hash_here

# ==================== CLOUDINARY (File Upload) ====================
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# ==================== EMAIL CONFIGURATION ====================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# ==================== GOOGLE OAUTH ====================
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=client_secret_here
# Optional override. If empty, backend auto-computes callback as:
# {request-protocol}://{request-host}/api/auth/google/callback
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# ==================== GENERAL ====================
NODE_ENV=development
PORT=5000

# ==================== PII ENCRYPTION (REQUIRED - 32 chars or 64 hex chars) ====================
# This key is used to encrypt sensitive donor data (name, phone, email) in the database.
# Generate a 32-byte key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PII_ENCRYPTION_KEY=your_32_char_encryption_key_or_64_char_hex_xxxxxxxx

# ==================== LOGGING ====================
LOG_LEVEL=info

# ==================== SECURITY NOTES ====================
# IMPORTANT SECURITY REQUIREMENTS:
# 1. All JWT_SECRET variables MUST be unique - never reuse the same secret
# 2. All secrets MUST be at least 32 characters long (256 bits)
# 3. Secrets must be cryptographically random, not passwords or patterns
# 4. Generate secrets using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 5. In production, use strong passwords for admin account
# 6. Use environment variables from a secure .env file - NEVER commit to git
# 7. In production: set AUTH_COOKIE_SECURE=true and AUTH_COOKIE_SAME_SITE=none
# 8. In production: set NODE_ENV=production
# 9. HTTPS/TLS is required for secure cookie transmission in production
